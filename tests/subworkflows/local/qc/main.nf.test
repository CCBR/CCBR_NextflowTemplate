nextflow_workflow {

    name "Test Workflow qc"
    script "subworkflows/local/qc/main.nf"
    workflow "qc"

    test("sarscov2 single-end [fastq]") {

        when {
            workflow {
                """
                input[0] = file(params.test_data['sarscov2']['illumina'].test_1_fastq_gz, checkIfExists: true)
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.out.fastqc_html[0][1] ==~ ".*/test.*.html"
            assert workflow.out.fastqc_zip[0][1] ==~ ".*/test.*.zip"
            assert path(workflow.out.fastqc_html[0][1]).text.contains("<tr><td>File type</td><td>Conventional base calls</td></tr>")
        }

    }

}
